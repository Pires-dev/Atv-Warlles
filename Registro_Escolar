int cpfValido(char cpf[]) {
    char d[11];
    int j = 0;

    // Extrai apenas os dígitos
    for(int i = 0; cpf[i] != '\0' && j < 11; i++)
        if(isdigit(cpf[i])) d[j++] = cpf[i];

    if(j != 11) return 0;

    // Rejeita CPFs com todos os dígitos iguais (ex: 111.111.111-11)
    int iguais = 1;
    for(int i = 1; i < 11; i++)
        if(d[i] != d[0]) { iguais = 0; break; }
    if(iguais) return 0;

    // Valida 1º dígito verificador
    int soma = 0;
    for(int i = 0; i < 9; i++) soma += (d[i] - '0') * (10 - i);
    int r1 = (soma * 10) % 11;
    if(r1 == 10) r1 = 0;
    if(r1 != d[9] - '0') return 0;

    // Valida 2º dígito verificador
    soma = 0;
    for(int i = 0; i < 10; i++) soma += (d[i] - '0') * (11 - i);
    int r2 = (soma * 10) % 11;
    if(r2 == 10) r2 = 0;
    if(r2 != d[10] - '0') return 0;

    return 1;
}

void formatarCPF(char cpf[], char saida[]) {
    char d[11];
    int j = 0;
    for(int i = 0; cpf[i] != '\0' && j < 11; i++)
        if(isdigit(cpf[i])) d[j++] = cpf[i];

    sprintf(saida, "%c%c%c.%c%c%c.%c%c%c-%c%c",
            d[0],d[1],d[2],d[3],d[4],d[5],d[6],d[7],d[8],d[9],d[10]);
}

int cpfExiste(char cpf[]) {
