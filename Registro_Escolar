int gerarMatricula() {
    FILE *arquivo = fopen(bancoAtual, "r");
    if(arquivo == NULL) return 202601;

    Aluno a;
    int ultima = 202600;

    while(fscanf(arquivo, "%d;%49[^;];%d;%49[^;];%9[^;];%d\n",
           &a.id, a.nome, &a.idade, a.curso, a.sala, &a.matricula) != EOF)
        ultima = a.matricula;

    fclose(arquivo);
    return ultima + 1;
}

void adicionarAluno() {
    FILE *arquivo = fopen(bancoAtual, "a");
    if(arquivo == NULL) { printf("Erro ao abrir arquivo!\n"); return; }

    Aluno a;
    char entrada[20];

    a.id        = gerarID();
    a.matricula = gerarMatricula();

    do {
        printf("\nNome: ");
        fgets(a.nome, sizeof(a.nome), stdin);
        a.nome[strcspn(a.nome, "\n")] = 0;
        removerEspacos(a.nome);
        if(!nomeValido(a.nome)) printf("Nome invalido!\n");
    } while(!nomeValido(a.nome));

    if(registroExiste(a.nome)) {
        printf("\nERRO: Nome ja cadastrado!\n");
        fclose(arquivo);
        return;
    }

    do {
        printf("Idade: ");
        fgets(entrada, sizeof(entrada), stdin);
        entrada[strcspn(entrada, "\n")] = 0;
        if(sscanf(entrada, "%d", &a.idade) != 1 || a.idade < 1 || a.idade > 100) {
            printf("Idade invalida! Digite entre 1 e 100.\n");
            a.idade = -1;
        }
    } while(a.idade < 1 || a.idade > 100);

    printf("Curso: ");
    fgets(a.curso, sizeof(a.curso), stdin);
    a.curso[strcspn(a.curso, "\n")] = 0;
    removerEspacos(a.curso);

    printf("Sala: ");
    fgets(a.sala, sizeof(a.sala), stdin);
    a.sala[strcspn(a.sala, "\n")] = 0;
    removerEspacos(a.sala);

    fprintf(arquivo, "%d;%s;%d;%s;%s;%d\n",
            a.id, a.nome, a.idade, a.curso, a.sala, a.matricula);
    fclose(arquivo);

    printf("\n=================================\n");
    printf("Aluno adicionado com sucesso!\n");
    printf("=================================\n");
}

