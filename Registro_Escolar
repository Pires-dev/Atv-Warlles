void limparBuffer() {
    while(getchar() != '\n');
}

void removerEspacos(char str[]) {
    int i = 0, j = 0, espaco = 0;
    char temp[100];

    while(str[i] == ' ') i++;

    for(; str[i] != '\0'; i++) {
        if(str[i] != ' ') {
            temp[j++] = str[i];
            espaco = 0;
        } else if(!espaco) {
            temp[j++] = ' ';
            espaco = 1;
        }
    }

    if(j > 0 && temp[j-1] == ' ') j--;
    temp[j] = '\0';
    strcpy(str, temp);
}

int nomeValido(char nome[]) {
    int letras = 0;
    for(int i = 0; nome[i] != '\0'; i++) {
        if(isalpha(nome[i])) letras = 1;
        else if(nome[i] != ' ') return 0;
    }
    return letras;
}

// Lê apenas o primeiro campo (id) de cada linha — funciona para qualquer formato
int gerarID() {
    FILE *arquivo = fopen(bancoAtual, "r");
    if(arquivo == NULL) return 1;

    char linha[200];
    int id, ultimoID = 0;

    while(fgets(linha, sizeof(linha), arquivo) != NULL)
        if(sscanf(linha, "%d;", &id) == 1)
            ultimoID = id;

    fclose(arquivo);
    return ultimoID + 1;
}

// Lê o segundo campo (nome) de cada linha — funciona para qualquer formato
int registroExiste(char nome[]) {
    FILE *arquivo = fopen(bancoAtual, "r");
    if(arquivo == NULL) return 0;

    char linha[200], nomeArq[50];

    while(fgets(linha, sizeof(linha), arquivo) != NULL)
        if(sscanf(linha, "%*d;%49[^;]", nomeArq) == 1)
            if(strcmp(nomeArq, nome) == 0) {
                fclose(arquivo);
                return 1;
            }

    fclose(arquivo);
    return 0;
}

// Exclusão genérica: pula a linha cujo ID bate, sem precisar conhecer o formato
void excluirRegistro() {
    FILE *arquivo = fopen(bancoAtual, "r");
    FILE *temp    = fopen("temp.txt", "w");

    if(arquivo == NULL) {
        printf("\nBanco vazio!\n");
        fclose(temp);
        remove("temp.txt");
        return;
    }

    int idExcluir, encontrado = 0, id;
    char confirmar, linha[200];

    printf("\nDigite o ID para excluir: ");
    scanf("%d", &idExcluir);
    limparBuffer();

    printf("Tem certeza? (s/n): ");
    scanf("%c", &confirmar);

    if(confirmar != 's' && confirmar != 'S') {
        fclose(arquivo);
        fclose(temp);
        remove("temp.txt");
        printf("\nExclusao cancelada!\n");
        return;
    }

    while(fgets(linha, sizeof(linha), arquivo) != NULL) {
        sscanf(linha, "%d;", &id);
        if(id != idExcluir)
            fputs(linha, temp);
        else
            encontrado = 1;
    }

    fclose(arquivo);
    fclose(temp);
    remove(bancoAtual);
    rename("temp.txt", bancoAtual);

    printf(encontrado ? "\nRegistro excluido com sucesso!\n" : "\nID nao encontrado!\n");
}

