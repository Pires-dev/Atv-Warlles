int cpfValido(char cpf[]) {
    int digitos = 0;

    
    
    for(int i = 0; cpf[i] != '\0'; i++) {
        if(isdigit(cpf[i]))
            digitos++;
        else if(cpf[i] != '.' && cpf[i] != '-')
            return 0;
    }

    
    return digitos == 11;
}

void formatarCPF(char cpf[], char saida[]) {
    char d[11];
    int j = 0;
    for(int i = 0; cpf[i] != '\0' && j < 11; i++)
        if(isdigit(cpf[i])) d[j++] = cpf[i];

    sprintf(saida, "%c%c%c.%c%c%c.%c%c%c-%c%c",
            d[0],d[1],d[2],d[3],d[4],d[5],d[6],d[7],d[8],d[9],d[10]);
}

