                    printf("Disciplina invalida! Use letras, espacos, hifen ou barra.\n");
            } while(!disciplinaValida(p.disciplina));

            
            
            int cpfOk = 0;
            while(!cpfOk) {
                do {
                    printf("Novo CPF (somente numeros ou XXX.XXX.XXX-XX): ");
                    fgets(cpfBruto, sizeof(cpfBruto), stdin);
                    cpfBruto[strcspn(cpfBruto, "\n")] = 0;
                    if(!cpfValido(cpfBruto))
                        printf("CPF invalido! Verifique os digitos.\n");
                } while(!cpfValido(cpfBruto));

                formatarCPF(cpfBruto, cpfFormatado);

                
                if(strcmp(cpfFormatado, cpfAntigo) == 0 || !cpfExiste(cpfFormatado)) {
                    cpfOk = 1;
                } else {
                    printf("ERRO: CPF ja cadastrado! Digite outro CPF.\n");
                }
            }

            strcpy(p.cpf, cpfFormatado);
            encontrado = 1;
        }

        
        fprintf(temp, "%d;%s;%d;%s;%s\n",
                p.id, p.nome, p.idade, p.disciplina, p.cpf);
    }

    fclose(arquivo);
    fclose(temp);
    remove(bancoAtual);
    rename("temp.txt", bancoAtual);

    if(encontrado) {
        printf("\n=================================\n");
        printf("Registro alterado!\n\n");
        printf("ANTES:  %s | %d anos | %s | %s\n", nomeAntigo, idadeAntiga, discAntiga, cpfAntigo);
        printf("DEPOIS: %s | %d anos | %s | %s\n", p.nome, p.idade, p.disciplina, p.cpf);
        printf("=================================\n");
    } else {
        printf("\nNome nao encontrado!\n");
    }
}

