        if(!cpfValido(cpfBruto))
            printf("CPF invalido! Verifique os digitos e tente novamente.\n");
    } while(!cpfValido(cpfBruto));

    formatarCPF(cpfBruto, cpfFormatado);

    if(cpfExiste(cpfFormatado)) {
        printf("\nERRO: CPF ja cadastrado!\n");
        fclose(arquivo);
        return;
