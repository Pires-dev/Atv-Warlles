    FILE *arquivo = fopen(bancoAtual, "a");
    if(arquivo == NULL) { printf("Erro ao abrir arquivo!\n"); return; }

    Professor p;
    char entrada[20];

    
    char cpfBruto[16], cpfFormatado[15];

    p.id = gerarID();

    
    
    int nomeOk = 0;
    while(!nomeOk) {
        do {
            printf("\nNome: ");
            fgets(p.nome, sizeof(p.nome), stdin);
            p.nome[strcspn(p.nome, "\n")] = 0;
            removerEspacos(p.nome);
            if(!nomeValido(p.nome)) printf("Nome invalido! Use apenas letras e espacos.\n");
        } while(!nomeValido(p.nome));

        if(registroExiste(p.nome)) {
            printf("ERRO: Nome ja cadastrado! Digite outro nome.\n");
        } else {
            nomeOk = 1;
        }
    }

    
    do {
        printf("Idade: ");
        fgets(entrada, sizeof(entrada), stdin);
        entrada[strcspn(entrada, "\n")] = 0;
        if(sscanf(entrada, "%d", &p.idade) != 1 || p.idade < 18 || p.idade > 100) {
            printf("Idade invalida! Professor deve ter entre 18 e 100 anos.\n");
            p.idade = -1;
        }
    } while(p.idade < 18 || p.idade > 100);

    
    do {
        printf("Disciplina: ");
        fgets(p.disciplina, sizeof(p.disciplina), stdin);
        p.disciplina[strcspn(p.disciplina, "\n")] = 0;
        removerEspacos(p.disciplina);
        if(!disciplinaValida(p.disciplina))
            printf("Disciplina invalida! Use letras, espacos, hifen ou barra (ex: Ed. Fisica).\n");
    } while(!disciplinaValida(p.disciplina));

    
    do {
        printf("CPF (somente numeros ou XXX.XXX.XXX-XX): ");
        fgets(cpfBruto, sizeof(cpfBruto), stdin);
        cpfBruto[strcspn(cpfBruto, "\n")] = 0;
        if(!cpfValido(cpfBruto))
            printf("CPF invalido! Verifique os digitos e tente novamente.\n");
    } while(!cpfValido(cpfBruto));

    formatarCPF(cpfBruto, cpfFormatado);

    if(cpfExiste(cpfFormatado)) {
        printf("\nERRO: CPF ja cadastrado!\n");
        fclose(arquivo);
        return;
    }

    strcpy(p.cpf, cpfFormatado);

    fprintf(arquivo, "%d;%s;%d;%s;%s\n",
            p.id, p.nome, p.idade, p.disciplina, p.cpf);
    fclose(arquivo);

    printf("\n=================================\n");
    printf("Professor adicionado com sucesso!\n");
    printf("=================================\n");
}

