// MENU
// ======================================
int main() {

    escolherBanco();

    int op;

    do {

        printf("\n=================================\n");
        printf("              MENU\n");
        printf("=================================\n");

        printf("1 - Adicionar\n");
        printf("2 - Listar\n");
        printf("3 - Buscar\n");
        printf("4 - Editar\n");
        printf("5 - Excluir\n");
        printf("6 - Trocar banco\n");
        printf("0 - Sair\n");

        printf("\nOpcao: ");

        scanf("%d", &op);

        limparBuffer();

        switch(op) {

            case 1:
                adicionar();
                break;

            case 2:
                listar();
                break;

            case 3:
                buscar();
                break;

            case 4:
                editar();
                break;

            case 5:
                excluirRegistro();
                break;

            case 6:
                escolherBanco();
                break;

            case 0:
                printf("\nSaindo...\n");
                break;

            default:
                printf("\nOpcao invalida!\n");
        }

    } while(op != 0);

    return 0;
}
