#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

#define MAX 100

typedef struct {
    int id;
    char nome[50];
    int idade;
} Pessoa;

char bancoAtual[50];

// ======================================
// LIMPAR BUFFER
// ======================================
void limparBuffer() {
    while(getchar() != '\n');
}

// ======================================
// REMOVER ESPAÇOS EXTRAS
// ======================================
void removerEspacos(char str[]) {

    int i, j = 0;
    int espaco = 0;

    char temp[100];

    for(i = 0; str[i] != '\0'; i++) {

        if(str[i] != ' ') {
            temp[j++] = str[i];
            espaco = 0;
        }
        else if(!espaco) {
            temp[j++] = ' ';
            espaco = 1;
        }
    }

    temp[j] = '\0';

    strcpy(str, temp);
}

// ======================================
// VALIDAR NOME
// ======================================
int nomeValido(char nome[]) {

    int letras = 0;

    for(int i = 0; nome[i] != '\0'; i++) {

        if(isalpha(nome[i])) {
            letras = 1;
        }
        else if(nome[i] != ' ') {
            return 0;
        }
    }

    return letras;
}

// ======================================
// GERAR ID AUTOMÁTICO
// ======================================
int gerarID() {

    FILE *arquivo = fopen(bancoAtual, "r");

    if(arquivo == NULL) {
        return 1;
    }

    Pessoa p;

    int ultimoID = 0;

    while(fscanf(arquivo,
           "%d;%49[^;];%d\n",
           &p.id,
           p.nome,
           &p.idade) != EOF) {

        ultimoID = p.id;
    }

    fclose(arquivo);

    return ultimoID + 1;
}

// ======================================
// VERIFICAR NOMES DUPLICADOS
// ======================================
int registroExiste(char nome[]) {

    FILE *arquivo = fopen(bancoAtual, "r");

    if(arquivo == NULL) {
        return 0;
    }

    Pessoa p;

    while(fscanf(arquivo,
           "%d;%49[^;];%d\n",
           &p.id,
           p.nome,
           &p.idade) != EOF) {

        if(strcmp(p.nome, nome) == 0) {

            fclose(arquivo);

            return 1;
        }
    }

    fclose(arquivo);

    return 0;
}

// ======================================
// ESCOLHER BANCO
// ======================================
void escolherBanco() {

    int op;

    printf("\n=================================\n");
    printf("       ESCOLHER BANCO\n");
    printf("=================================\n");

    printf("1 - Alunos\n");
    printf("2 - Professores\n");

    printf("\nEscolha: ");

    scanf("%d", &op);

    limparBuffer();

    if(op == 1) {
        strcpy(bancoAtual, "alunos.txt");
    }
    else {
        strcpy(bancoAtual, "professores.txt");
    }

    printf("\nBanco selecionado: %s\n", bancoAtual);
}

// ======================================
// ADICIONAR
// ======================================
void adicionar() {

    FILE *arquivo = fopen(bancoAtual, "a");

    if(arquivo == NULL) {

        printf("Erro ao abrir arquivo!\n");

        return;
    }

    Pessoa p;

    char entrada[20];

    // ======================
    // GERAR ID
    // ======================
    p.id = gerarID();

    // ======================
    // VALIDAR NOME
    // ======================
    do {

        printf("\nNome: ");

        fgets(p.nome, sizeof(p.nome), stdin);

        p.nome[strcspn(p.nome, "\n")] = 0;

        removerEspacos(p.nome);

        if(!nomeValido(p.nome)) {

            printf("Nome invalido!\n");
        }

    } while(!nomeValido(p.nome));

    // ======================
    // VERIFICAR DUPLICADOS
    // ======================
    if(registroExiste(p.nome)) {

        printf("\nERRO: Nome ja cadastrado!\n");

        fclose(arquivo);

        return;
    }

    // ======================
    // VALIDAR IDADE
    // ======================
    do {

        printf("Idade: ");

        fgets(entrada, sizeof(entrada), stdin);

        entrada[strcspn(entrada, "\n")] = 0;

        if(sscanf(entrada, "%d", &p.idade) != 1 ||
           p.idade < 1 ||
           p.idade > 100) {

            printf("Idade invalida! Digite entre 1 e 100.\n");

            p.idade = -1;
        }

    } while(p.idade < 1 || p.idade > 100);

    // ======================
    // SALVAR
    // ======================
    fprintf(arquivo,
            "%d;%s;%d\n",
            p.id,
            p.nome,
            p.idade);

    fclose(arquivo);

    printf("\n=================================\n");
    printf("Registro adicionado com sucesso!\n");
    printf("=================================\n");
}

// ======================================
// LISTAR
// ======================================
void listar() {

    FILE *arquivo = fopen(bancoAtual, "r");

    if(arquivo == NULL) {

        printf("\nBanco vazio!\n");

        return;
    }

    Pessoa pessoas[MAX];

    int total = 0;

    while(fscanf(arquivo,
           "%d;%49[^;];%d\n",
           &pessoas[total].id,
           pessoas[total].nome,
           &pessoas[total].idade) != EOF) {

        total++;
    }

    fclose(arquivo);

    // ======================
    // ORDENAR POR ID
    // ======================
    for(int i = 0; i < total - 1; i++) {

        for(int j = i + 1; j < total; j++) {

            if(pessoas[i].id > pessoas[j].id) {

                Pessoa temp = pessoas[i];

                pessoas[i] = pessoas[j];

                pessoas[j] = temp;
            }
        }
    }

    printf("\n=================================================\n");

    printf("| %-5s | %-25s | %-5s |\n",
           "ID",
           "NOME",
           "IDADE");

    printf("=================================================\n");

    for(int i = 0; i < total; i++) {

        printf("| %-5d | %-25s | %-5d |\n",
               pessoas[i].id,
               pessoas[i].nome,
               pessoas[i].idade);
    }

    printf("=================================================\n");
}

// ======================================
// BUSCAR
// ======================================
void buscar() {

    FILE *arquivo = fopen(bancoAtual, "r");

    if(arquivo == NULL) {

        printf("\nBanco vazio!\n");

        return;
    }

    Pessoa p;

    int idBusca;
    int encontrado = 0;

    printf("\nDigite o ID: ");

    scanf("%d", &idBusca);

    limparBuffer();

    while(fscanf(arquivo,
           "%d;%49[^;];%d\n",
           &p.id,
           p.nome,
           &p.idade) != EOF) {

        if(p.id == idBusca) {

            printf("\n=================================\n");

            printf("Registro encontrado!\n");

            printf("ID: %d\n", p.id);
            printf("Nome: %s\n", p.nome);
            printf("Idade: %d\n", p.idade);

            printf("=================================\n");

            encontrado = 1;

            break;
        }
    }

    if(!encontrado) {

        printf("\nRegistro nao encontrado!\n");
    }

    fclose(arquivo);
}

// ======================================
// EDITAR
// ======================================
void editar() {

    FILE *arquivo = fopen(bancoAtual, "r");
    FILE *temp = fopen("temp.txt", "w");

    if(arquivo == NULL) {

        printf("\nBanco vazio!\n");

        return;
    }

    Pessoa p;

    int idEditar;
    int encontrado = 0;

    char entrada[20];

    char nomeAntigo[50];
    int idadeAntiga;

    printf("\nDigite o ID para editar: ");

    scanf("%d", &idEditar);

    limparBuffer();

    while(fscanf(arquivo,
           "%d;%49[^;];%d\n",
           &p.id,
           p.nome,
           &p.idade) != EOF) {

        if(p.id == idEditar) {

            strcpy(nomeAntigo, p.nome);

            idadeAntiga = p.idade;

            // ======================
            // NOVO NOME
            // ======================
            do {

                printf("Novo nome: ");

                fgets(p.nome, sizeof(p.nome), stdin);

                p.nome[strcspn(p.nome, "\n")] = 0;

                removerEspacos(p.nome);

                if(!nomeValido(p.nome)) {

                    printf("Nome invalido!\n");
                }

            } while(!nomeValido(p.nome));

            // ======================
            // NOVA IDADE
            // ======================
            do {

                printf("Nova idade: ");

                fgets(entrada, sizeof(entrada), stdin);

                entrada[strcspn(entrada, "\n")] = 0;

                if(sscanf(entrada, "%d", &p.idade) != 1 ||
                   p.idade < 1 ||
                   p.idade > 100) {

                    printf("Idade invalida! Digite entre 1 e 100.\n");

                    p.idade = -1;
                }

            } while(p.idade < 1 || p.idade > 100);

            encontrado = 1;
        }

        fprintf(temp,
                "%d;%s;%d\n",
                p.id,
                p.nome,
                p.idade);
    }

    fclose(arquivo);
    fclose(temp);

    remove(bancoAtual);

    rename("temp.txt", bancoAtual);

    if(encontrado) {

        printf("\n=================================\n");

        printf("Registro alterado com sucesso!\n\n");

        printf("ANTES:\n");
        printf("Nome: %s\n", nomeAntigo);
        printf("Idade: %d\n\n", idadeAntiga);

        printf("DEPOIS:\n");
        printf("Nome: %s\n", p.nome);
        printf("Idade: %d\n", p.idade);

        printf("=================================\n");
    }
    else {

        printf("\nID nao encontrado!\n");
    }
}

// ======================================
// EXCLUIR
// ======================================
void excluirRegistro() {

    FILE *arquivo = fopen(bancoAtual, "r");
    FILE *temp = fopen("temp.txt", "w");

    if(arquivo == NULL) {

        printf("\nBanco vazio!\n");

        return;
    }

    Pessoa p;

    int idExcluir;
    int encontrado = 0;

    char confirmar;

    printf("\nDigite o ID para excluir: ");

    scanf("%d", &idExcluir);

    limparBuffer();

    printf("Tem certeza? (s/n): ");

    scanf("%c", &confirmar);

    if(confirmar != 's' && confirmar != 'S') {

        fclose(arquivo);
        fclose(temp);

        remove("temp.txt");

        printf("\nExclusao cancelada!\n");

        return;
    }

    while(fscanf(arquivo,
           "%d;%49[^;];%d\n",
           &p.id,
           p.nome,
           &p.idade) != EOF) {

        if(p.id != idExcluir) {

            fprintf(temp,
                    "%d;%s;%d\n",
                    p.id,
                    p.nome,
                    p.idade);
        }
        else {

            encontrado = 1;
        }
    }

    fclose(arquivo);
    fclose(temp);

    remove(bancoAtual);

    rename("temp.txt", bancoAtual);

    if(encontrado) {

        printf("\nRegistro excluido com sucesso!\n");
    }
    else {

        printf("\nID nao encontrado!\n");
    }
}

