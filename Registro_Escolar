    Professor p;
    while(fscanf(arquivo, "%d;%49[^;];%d;%49[^;];%14[^\n]\n",
           &p.id, p.nome, &p.idade, p.disciplina, p.cpf) != EOF)
        if(strcmp(p.cpf, cpf) == 0) {
            fclose(arquivo);
            return 1;
        }

    fclose(arquivo);
    return 0;
}

