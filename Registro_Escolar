        switch(op) {
            case 1: ehAluno ? adicionarAluno()    : adicionarProfessor();  break;
            case 2: ehAluno ? listarAlunos()      : listarProfessores();   break;
            case 3: ehAluno ? buscarAluno()       : buscarProfessor();     break;
            case 4: ehAluno ? editarAluno()       : editarProfessor();     break;
            case 5: excluirRegistro();                                      break;
            case 6: escolherBanco();                                        break;
            case 0: printf("\nSaindo...\n");                               break;
            default: printf("\nOpcao invalida!\n");
        }
    } while(op != 0);

    return 0;
}
