void limparBuffer() {
    while(getchar() != '\n');
}

void removerEspacos(char str[]) {
    int i = 0, j = 0, espaco = 0;
    char temp[100];

    
    while(str[i] == ' ') i++;

    for(; str[i] != '\0'; i++) {
        if(str[i] != ' ') {
            temp[j++] = str[i];
            espaco = 0;
        } else if(!espaco) {
            
            temp[j++] = ' ';
            espaco = 1;
        }
    }

    
    if(j > 0 && temp[j-1] == ' ') j--;
    temp[j] = '\0';
    strcpy(str, temp);
}

int nomeValido(char nome[]) {
    int letras = 0;
    for(int i = 0; nome[i] != '\0'; i++) {
        if(isalpha(nome[i])) letras = 1;
        else if(nome[i] != ' ') return 0;   
    }
    return letras;   
}

int cursoValido(char curso[]) {
    int letras = 0;
    for(int i = 0; curso[i] != '\0'; i++) {
        if(isalpha(curso[i])) letras = 1;
        else if(curso[i] != ' ') return 0;  
    }
    return letras;
}

int salaValida(char sala[]) {
    
    if(strlen(sala) != 2) return 0;
    
    return (isdigit(sala[0]) && sala[0] != '0' && isupper(sala[1]));
}

int disciplinaValida(char disc[]) {
    int letras = 0;
    for(int i = 0; disc[i] != '\0'; i++) {
        if(isalpha(disc[i])) letras = 1;
        else if(disc[i] != ' ' && disc[i] != '-' && disc[i] != '/' && disc[i] != '.') return 0;
    }
    return letras;
}

int gerarID() {
    FILE *arquivo = fopen(bancoAtual, "r");
    if(arquivo == NULL) return 1;   

    char linha[200];
    int id, ultimoID = 0;

    
    while(fgets(linha, sizeof(linha), arquivo) != NULL)
        if(sscanf(linha, "%d;", &id) == 1)
            ultimoID = id;

    fclose(arquivo);
    return ultimoID + 1;
}

int registroExiste(char nome[]) {
    FILE *arquivo = fopen(bancoAtual, "r");
    if(arquivo == NULL) return 0;

    char linha[200], nomeArq[50];

    
    while(fgets(linha, sizeof(linha), arquivo) != NULL)
        if(sscanf(linha, "%*d;%49[^;]", nomeArq) == 1)
            if(strcmp(nomeArq, nome) == 0) {
                fclose(arquivo);
                return 1;
            }

    fclose(arquivo);
    return 0;
}

void excluirRegistro() {
    FILE *arquivo = fopen(bancoAtual, "r");
    FILE *temp    = fopen("temp.txt", "w");

    if(arquivo == NULL) {
        printf("\nBanco vazio!\n");
        fclose(temp);
        remove("temp.txt");
        return;
    }

    char nomeExcluir[50], confirmar, linha[200], nomeArq[50];
    int encontrado = 0;

    printf("\nDigite o nome para excluir: ");
    fgets(nomeExcluir, sizeof(nomeExcluir), stdin);
    nomeExcluir[strcspn(nomeExcluir, "\n")] = 0;
    removerEspacos(nomeExcluir);

    printf("Tem certeza? (s/n): ");
    scanf("%c", &confirmar);
    limparBuffer();

    if(confirmar != 's' && confirmar != 'S') {
        fclose(arquivo);
        fclose(temp);
        remove("temp.txt");
        printf("\nExclusao cancelada!\n");
        return;
    }

    
    while(fgets(linha, sizeof(linha), arquivo) != NULL) {
        
        if(sscanf(linha, "%*d;%49[^;]", nomeArq) == 1 && strcmp(nomeArq, nomeExcluir) == 0)
            encontrado = 1;   
        else
            fputs(linha, temp);   
    }

    fclose(arquivo);
    fclose(temp);
    
    remove(bancoAtual);
    rename("temp.txt", bancoAtual);

    printf(encontrado ? "\nRegistro excluido com sucesso!\n" : "\nNome nao encontrado!\n");
}

